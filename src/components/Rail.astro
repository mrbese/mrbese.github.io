---
import { site } from '../data/site.ts';
const facts: [string, string][] = [
  ['Location', site.location],
  ['Focus', site.focus],
  ['Now', site.now],
];
---
<div class="rail">
  <a class="status" href="/applying">
    <span class="dot"></span> open to work
  </a>
  {facts.map(([k, v]) => (
    <div class="fact"><div class="k">{k}</div><div class="v">{v}</div></div>
  ))}
</div>
<style>
  .rail{border-right:1px solid var(--line);padding:44px 28px 44px var(--gutter);display:flex;flex-direction:column;gap:22px}
  .status{display:flex;align-items:center;gap:9px;font-size:10.5px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink-2);transition:color var(--dur)}
  .status:hover{color:var(--filament)}
  .dot{width:7px;height:7px;border-radius:99px;background:var(--filament);display:inline-block;flex:none}
  .fact .k{font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink-3);margin-bottom:5px}
  .fact .v{font-size:13.5px;line-height:1.45;color:var(--ink-1)}
  @media(max-width:760px){.rail{border-right:none;border-bottom:1px solid var(--line);flex-direction:row;flex-wrap:wrap;gap:22px 32px;padding:24px var(--gutter)}}
</style>
