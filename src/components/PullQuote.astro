---
interface Props {
  attribution?: string;
}
const { attribution } = Astro.props;
---
<blockquote class="pull">
  <q><slot /></q>
  {attribution && <span class="att">{attribution}</span>}
</blockquote>
<style>
  .pull{margin:44px 0;padding-left:26px;border-left:2px solid var(--filament)}
  .pull q{font-family:var(--serif);font-style:italic;font-size:clamp(22px,2.6vw,28px);line-height:1.35;color:var(--ink-0);quotes:none}
  .pull .att{display:block;margin-top:14px;font-family:var(--font);font-size:12px;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-3);font-style:normal}
</style>
