---
import { social } from '../data/social.ts';
---
<footer class="foot">
  <div class="a">
    <span class="wm">omer bese.</span>
    <nav class="fl" aria-label="Elsewhere">
      {social.map((s) => <a href={s.href} rel="me">{s.label}</a>)}
    </nav>
  </div>
  <span class="b">&copy; 2026 &middot; built by asking &ldquo;why?&rdquo;</span>
</footer>
<style>
  .foot{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:24px var(--gutter);border-top:1px solid var(--line-strong);flex-wrap:wrap}
  .a{display:flex;align-items:baseline;gap:22px;flex-wrap:wrap}
  .wm{font-size:13px;color:var(--ink-2)}
  .fl{display:flex;gap:18px}
  .fl a{font-size:12.5px;color:var(--ink-3);transition:color var(--dur)}
  .fl a:hover{color:var(--filament)}
  .b{font-size:11.5px;letter-spacing:0.06em;color:var(--ink-3)}
</style>
