---
import { Picture } from 'astro:assets';
import banner from '../assets/hero-banner-dark.png';
---
<div class="banner">
  <Picture
    src={banner}
    alt="OMER BESE, with a portrait inside the O"
    widths={[640, 1180, 2360]}
    sizes="(max-width: 1180px) 100vw, 1180px"
    formats={['avif', 'webp']}
    fallbackFormat="png"
    loading="eager"
    fetchpriority="high"
  />
  <div class="tag">energy engineer &middot; builder</div>
</div>
<style>
  .banner{border-bottom:1px solid var(--line)}
  .banner :global(img){width:100%;max-width:none;height:auto;display:block}
  .banner .tag{padding:20px var(--gutter) clamp(28px,4vw,44px);font-size:11px;letter-spacing:0.22em;text-transform:uppercase;color:var(--ink-2)}
</style>
