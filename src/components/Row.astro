---
interface Props {
  label: string;
  first?: boolean;
}
const { label, first } = Astro.props;
---
<div class:list={['row', { first }]}>
  <div class="l"><span>{label}</span></div>
  <div class="b"><slot /></div>
</div>
<style>
  .row{display:grid;grid-template-columns:var(--rail) 1fr;border-top:1px solid var(--line)}
  .row.first{border-top:none}
  .l{border-right:1px solid var(--line);padding:30px 28px 30px var(--gutter)}
  .l span{font-size:11px;font-weight:500;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink-2)}
  .b{padding:30px var(--gutter) 30px 40px;min-width:0}
  @media(max-width:760px){
    .row{grid-template-columns:1fr}
    .l{border-right:none;border-bottom:1px solid var(--line);padding-bottom:14px}
    .b{padding:20px var(--gutter)}
  }
</style>
